{
  "productName": "Todo Flow",
  "version": "0.1.0",
  "identifier": "com.todoflow.todoflow",
  "app": {
    "windows": [
      {
        "title": "Todo Flow",
        "width": 800,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "useLocalToolsDir": true,
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/ORANGEYUANGUO/todo-flow/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5REZBNzI4NDg1QTdFMDEKUldRQmZscElLS2ZmNlliZm5JVmZ0YzU3MjRSQk1kWE8ybTBVQXk4Q2VtZFZyb0w5VGFWRlFlVjIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
