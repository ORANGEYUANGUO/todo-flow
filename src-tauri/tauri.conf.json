{
  "productName": "Todo Flow",
  "version": "0.1.0",
  "identifier": "com.todoflow.todoflow",
  "app": {
    "windows": [
      {
        "title": "Todo Flow",
        "width": 800,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "wix": {
        "language": "zh-CN"
      }
    }
  },
  "build": {
    "devUrl": "http://127.0.0.1:5173"
  }
}
